{
    "name": "pictomancer/wordpress-image-optimizer",
    "description": "WordPress plugin that optimizes Media Library images via the Pictomancer.ai API.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "pictomancer/pictomancer": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/pictomancer/php-sdk"
        }
    ],
    "autoload-dev": {
        "psr-4": {
            "Pictomancer\\WP\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": false
        }
    }
}
